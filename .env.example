# Local / homolog — apontar para couple-quiz-staging (org Carlos)
# Copie para .env.local e preencha com credenciais do Dashboard Supabase.

VITE_APP_ENV=local
VITE_SUPABASE_URL=https://SEU_REF_STAGING.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_staging

# Modo de desbloqueio:
# - (padrao) com URL + anon key: usa Supabase
# - local: forca storySchedule em content.js (dev sem Supabase)
# VITE_UNLOCK_MODE=local

# Producao: NAO colocar no .env.local — vars apenas na Vercel (Production).
